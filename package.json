{
  "name": "thisport",
  "version": "1.0.0",
  "description": "Decentralized Protocol",
  "author": "_hbk",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.thisport.protocol",
    "productName": "Thisport",
    "win": {
      "target": "nsis",
      "icon": "thisport.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking"
    },
    "dmg": {
      "title": "Install Thisport",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "express": "^4.22.1",
    "peer": "^1.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}